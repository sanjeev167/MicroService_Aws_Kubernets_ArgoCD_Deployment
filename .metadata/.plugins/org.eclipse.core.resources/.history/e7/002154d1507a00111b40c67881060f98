# =============================================================================
# GitHub Actions - Continuous Integration (CI)
# =============================================================================
# File        : ms-wallet-ci.yml
# Project     : MSIMPL - Microservices Platform
# Service     : ms-wallet
#
# Description
# -----------------------------------------------------------------------------
# This workflow performs Continuous Integration (CI) for the ms-wallet
# microservice.
#
# Activities Performed
# --------------------
# 1. Checkout source code
# 2. Configure JDK 17
# 3. Cache Maven dependencies
# 4. Build Spring Boot application
# 5. Verify generated JAR
# 6. Upload build artifact
# 7. Login to Docker Hub
# 8. Configure Docker Buildx
# 9. Cache Docker build layers
# 10. Build Docker Image
# 11. Verify Docker Image
#
# NOTE:
# Docker image push will be added in the next enhancement step.
#
# Environment : GitHub Actions
# JDK         : Temurin 17
# Runner      : ubuntu-latest
# Version     : 2.0.0
# Author      : Sanjeev Kumar
# =============================================================================

name: Wallet CI Workflow

run-name: Build & Package ms-wallet

on:

  push:

    branches:
      - main

    paths:
      - "ms-wallet/**"
      - ".github/workflows/ms-wallet-ci.yml"

permissions:
  contents: read

concurrency:
  group: wallet-ci-${{ github.ref }}
  cancel-in-progress: true

jobs:

  build-and-package:

    name: Build, Package & Verify

    runs-on: ubuntu-latest

    timeout-minutes: 20

    defaults:
      run:
        working-directory: ms-wallet

    steps:

      # --------------------------------------------------------
      # Step 1
      # Checkout Repository
      # --------------------------------------------------------

      - name: Checkout Repository
        uses: actions/checkout@v4

      # --------------------------------------------------------
      # Step 2
      # Setup Java 17 (Temurin)
      # --------------------------------------------------------

      - name: Setup JDK 17

        uses: actions/setup-java@v4

        with:
          distribution: temurin
          java-version: '17'

      # --------------------------------------------------------
      # Step 3
      # Verify Java Installation
      # --------------------------------------------------------

      - name: Verify Java Installation

        run: |
          java -version
          javac -version

      # --------------------------------------------------------
      # Step 4
      # Cache Maven Dependencies
      #
      # Purpose:
      #   Speeds up subsequent workflow executions by restoring
      #   the local Maven repository (~/.m2).
      #
      # Benefit:
      #   Avoids downloading unchanged dependencies every build.
      # --------------------------------------------------------

      - name: Cache Maven Dependencies

        uses: actions/cache@v4

        with:
          path: ~/.m2/repository
          key: ${{ runner.os }}-maven-${{ hashFiles('**/pom.xml') }}
          restore-keys: |
            ${{ runner.os }}-maven-

      # --------------------------------------------------------
      # Step 5
      # Build Spring Boot Application
      #
      # clean   -> Removes previous build artifacts
      # package -> Compiles source code and creates executable JAR
      # --------------------------------------------------------

      - name: Build Spring Boot Application

        run: mvn clean package

      # --------------------------------------------------------
      # Step 6
      # Verify Generated Build Artifact
      #
      # Displays the contents of the target directory to confirm
      # successful JAR creation.
      # --------------------------------------------------------

      - name: Verify Build Artifact

        run: |
          echo "Generated Build Artifacts"
          ls -lh target

      # --------------------------------------------------------
      # Step 7
      # Upload JAR Artifact
      #
      # Stores the generated JAR in GitHub Actions so it can be
      # downloaded later even if subsequent steps fail.
      # --------------------------------------------------------

      - name: Upload Build Artifact

        uses: actions/upload-artifact@v4

        with:
          name: ms-wallet-jar
          path: ms-wallet/target/*.jar

      # --------------------------------------------------------
      # Step 8
      # Login to Docker Hub
      #
      # Uses GitHub Secrets for secure authentication.
      # --------------------------------------------------------

      - name: Login to Docker Hub

        uses: docker/login-action@v3

        with:
          username: ${{ secrets.DOCKER_USERNAME }}
          password: ${{ secrets.DOCKER_PASSWORD }}

      # --------------------------------------------------------
      # Step 9
      # Setup Docker Buildx
      #
      # Buildx enables advanced Docker build capabilities such as
      # layer caching and multi-platform image creation.
      # --------------------------------------------------------

      - name: Setup Docker Buildx

        uses: docker/setup-buildx-action@v3

      # --------------------------------------------------------
      # Step 10
      # Cache Docker Build Layers
      #
      # Reuses previously built Docker layers to reduce image
      # build time.
      # --------------------------------------------------------

      - name: Cache Docker Layers

        uses: actions/cache@v4

        with:
          path: /tmp/.buildx-cache

          key: ${{ runner.os }}-buildx-${{ github.sha }}

          restore-keys: |
            ${{ runner.os }}-buildx-

      # --------------------------------------------------------
      # Step 11
      # Build Docker Image
      #
      # Builds the Docker image from the Dockerfile present in
      # the ms-wallet project.
      # --------------------------------------------------------

      - name: Build Docker Image

        run: |
          docker build \
            -t ${{ secrets.DOCKER_USERNAME }}/ms-wallet:latest \
            .

      # --------------------------------------------------------
      # Step 12
      # Verify Docker Image
      #
      # Displays locally available Docker images to confirm that
      # the image was successfully created.
      # --------------------------------------------------------

      - name: Verify Docker Image

        run: |
          docker images

      # --------------------------------------------------------
      # Step 13
      # Display Workflow Summary
      # --------------------------------------------------------

      - name: Display Workflow Summary

        run: |
          echo "======================================================="
          echo "MSIMPL - Continuous Integration"
          echo "Service      : ms-wallet"
          echo "JDK          : Temurin 17"
          echo "Build        : SUCCESS"
          echo "JAR          : Generated"
          echo "Docker Image : Built Successfully"
          echo "Status       : Ready for Docker Push"
          echo "======================================================="